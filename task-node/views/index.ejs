<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TASK MANAGER</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-black text-white "> 
    <!-- add task form -->
     <h1 class="text-3xl my-3 text-center font-semibold">task management file</h1>
     <div class="flex justify-center"></div>
     <form action="/create" method="POST" class="flex flex-col items-center  w-80 mx-auto">
        <input type="text" 
        class="px-4 py-2 bg-[#555]
              text-white outline-none rounded-md mb-2"
         name="Title"
         placeholder="Task Heading">
        <br />
        <input type="text" 
         class="px-4 py-2 bg-[#555]
               text-white outline-none rounded-md mb-2"
         name="Task"
         placeholder="Task Message">
        
         <br />

        <input type="submit" value="add task" class="w-full bg-orange-600
          px-4 py-2 rounded-md">
          <br />
     </form>
    </div>

<!-- task card --> 
    <div class="mt-8 flex justify-center flex-wrap">
        <% data.forEach(function(val){ %>

        <div class="bg-[#222] border border-red-500 rounded-md
         text-white p-4 w-1/4">
            <h1 class=" font-medium text-2xl pb-4"><%= val %></h1>
            <div class="flex justify-center"></div>
        <a class="text-blue-500 active:text-red-600" href="/file/<%= val %>">Read More</a>
        <a class="text-gray-600 active:text-red-600 " href="/file/<%= val %>">Edit File</a>
    </div>
          <%  }) %>
        </div>    
            </div >

</body>
</html>